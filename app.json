{
  "expo": {
    "name": "pravabloyai",
    "slug": "pravabloyai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "pravabloyai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo.png"
    },
    "android": {
      "package": "com.pravabloyai.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8DCFC",
        "foregroundImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4C0E9E",
          "image": "./assets/images/logo.png",
          "imageWidth": 120
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "753125db-9314-44d8-b37e-afa0e5647e89"
      }
    },
    "owner": "nivesh007"
  }
}
